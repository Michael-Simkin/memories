{
  "name": "memories-plugin",
  "private": true,
  "version": "0.2.30",
  "type": "module",
  "description": "Project-scoped memory plugin for Claude Code",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:backend && npm run build:web",
    "build:backend": "tsup --config tsup.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"web/**/*.{ts,tsx}\"",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project web/tsconfig.json --noEmit && tsc --project tsconfig.test.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "@tanstack/react-query": "^5.90.3",
    "express": "^5.1.0",
    "picomatch": "^4.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ulid": "^3.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/picomatch": "^4.0.2",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "supertest": "^7.2.2"
  }
}
