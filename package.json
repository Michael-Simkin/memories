{
  "name": "claude-memory-marketplace",
  "private": true,
  "version": "0.1.0",
  "description": "Claude Code plugin marketplace with the memories plugin",
  "workspaces": [
    "plugins/memories"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspace memories-plugin",
    "lint": "npm run lint --workspace memories-plugin",
    "typecheck": "npm run typecheck --workspace memories-plugin",
    "test": "npm run test --workspace memories-plugin",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.1",
    "vitest": "^3.2.4"
  }
}
