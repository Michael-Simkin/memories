{
  "name": "claude-memory-marketplace",
  "private": true,
  "version": "0.1.0",
  "description": "Claude Code plugin marketplace with memories plugin",
  "workspaces": [
    "plugins/memories"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build --workspace memories-plugin",
    "lint": "npm run lint --workspace memories-plugin",
    "typecheck": "npm run typecheck --workspace memories-plugin",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-import-x": "^4.8.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^7.1.4"
  }
}
